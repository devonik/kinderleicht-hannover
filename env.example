# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: API-Version festpinnen (Default in sanity/env.ts). Format: JJJJ-MM-TT
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-03
# Server-seitiges Token (nur für schreibende Zugriffe / dataset import), NICHT NEXT_PUBLIC
SANITY_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# E-Mail (Resend oder Postmark - eins auswählen)
RESEND_API_KEY=
# POSTMARK_API_KEY=

EMAIL_FROM=info@kinderleicht-hannover.de

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Live-Modus: "true" zeigt die echte Website mit Menü. Sonst / nicht gesetzt bleibt die
# Coming-Soon-/Maintenance-Seite aktiv und alle Routen außer Impressum/Datenschutz/Studio
# werden auf die Startseite umgeleitet. In Produktion erst zum Go-Live auf "true" setzen.
NEXT_PUBLIC_SITE_LIVE=false

# Vorschau-Schutz (Basic Auth). NUR in der Preview-Umgebung setzen, damit Charly geschützt
# draufschauen kann. In Produktion NICHT setzen -> Seite bleibt offen. PREVIEW_USER optional.
# PREVIEW_USER=kinderleicht
# PREVIEW_PASSWORD=
